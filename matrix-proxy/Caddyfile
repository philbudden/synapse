{
  storage file_system {
    root /data
  }

  # Prefer HTTP/1.1 + HTTP/2; some clients/networks can be flaky with HTTP/3 (QUIC).
  servers {
    protocols h1 h2
  }

  # On-demand TLS is used so clients can connect via LAN IP / Tailnet IP / MagicDNS.
  # (No global ask/permission configured; keep this service LAN/VPN-only.)
}

# Local TLS proxy for Matrix client-server API.
# Listen on all interfaces and provision a local (internal CA) certificate on-demand
# for whatever hostname/IP the client uses (LAN IP, Tailnet IP, MagicDNS name).
:{$MATRIX_TLS_PORT} {
  tls internal {
    on_demand
  }

  # Help clients that perform Matrix client discovery.
  handle /.well-known/matrix/client {
    respond {"m.homeserver":{"base_url":"https://{host}"}}
  }

  reverse_proxy matrix-synapse:8008
}
