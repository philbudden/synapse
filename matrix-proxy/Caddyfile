{
  storage file_system {
    root /data
  }

  # On-demand TLS is used so clients can connect via LAN IP / Tailnet IP / MagicDNS.
  # (No global ask/rate-limit configured; keep this service LAN/VPN-only.)
}

# Local TLS proxy for Matrix client-server API.
# Listen on all interfaces and provision a local (internal CA) certificate on-demand
# for whatever hostname/IP the client uses (LAN IP, Tailnet IP, MagicDNS name).
:{$MATRIX_TLS_PORT} {
  tls internal {
    on_demand
  }
  reverse_proxy matrix-synapse:8008
}
